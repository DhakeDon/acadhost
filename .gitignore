# ============================================================
# AcadHost — .gitignore
# ============================================================

# --- Secrets (NEVER commit) ---
.env
backend/.env
frontend/student-dashboard/.env
frontend/admin-dashboard/.env

# --- Dependencies (reinstalled via npm install) ---
node_modules/
backend/node_modules/
frontend/student-dashboard/node_modules/
frontend/admin-dashboard/node_modules/

# --- Built frontend files (regenerated via npm run build) ---
frontend/student-dashboard/dist/
frontend/admin-dashboard/dist/
frontend/student-dashboard/build/
frontend/admin-dashboard/build/

# --- Zip archives (not needed in repo) ---
*.zip
Backend.zip
nginx.zip
Admin-Dashboard.zip
Student-dashboard.zip
Acadhost.zip

# --- Student project files (runtime data, not code) ---
Projects/
projects/

# --- MRD docs (internal planning docs, not deployment code) ---
mrd/

# --- Admin files folder ---
admin-files/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS junk ---
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# --- IDE files ---
.idea/
.vscode/
*.iml

# --- Claude / AI tool files ---
.claude/

# --- Runtime generated nginx project configs ---
nginx/conf.d/acadhost/*.conf
!nginx/conf.d/acadhost/default.conf

# --- PM2 ---
.pm2/
ecosystem.config.js.bak